    {
      "parameters": {
        "jsCode": "const papers = $('Dedup & Filter New').first().json.papers || [];\n\nconst paperList = papers.slice(0, 10).map((p, i) => ({\n  index: i,\n  title: p.title,\n  abstract: (p.abstract || '').slice(0, 200),\n  source: p.source\n}));\n\nconst prompt = `You are a research paper curator. Rank these papers for someone interested in AI, LLMs, NLP, agents, computer vision.\n\nPapers:\n${JSON.stringify(paperList)}\n\nReturn ONLY a valid JSON array, no extra text, no markdown:\n[{\"index\": 0, \"score\": 9, \"tldr\": \"2 sentence summary\", \"why_relevant\": \"short phrase\"}]\nMax 8 papers sorted by score descending.`;\n\nreturn [{\n  json: {\n    model: \"llama-3.3-70b-versatile\",\n    temperature: 0.3,\n    messages: [{ role: \"user\", content: prompt }]\n  }\n}];"
      },
