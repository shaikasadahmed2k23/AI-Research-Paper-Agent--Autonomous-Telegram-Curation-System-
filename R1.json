      "id": "01a696a7-5b57-40ff-baec-fe472bb67535",
      "name": "Get User Preferences",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        -288,
        496
      ],
      "retryOnFail": true,
