      "id": "56a098fe-ff3f-4a4b-92b8-fef85b0970aa",
      "name": "Telegram Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        -656,
        96
      ],
      "webhookId": "telegram-feedback-hook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Debug - dekho kya aa raha hai\nconsole.log('Body:', JSON.stringify(body));\n\nconst reaction = body.message_reaction;\nconst callbackQuery = body.callback_query;\nconst message = body.message;\n\nlet messageId, chatId, reactionType, userId;\n\nif (reaction) {\n  messageId = reaction.message_id;\n  chatId = reaction.chat?.id;\n  userId = reaction.user?.id;\n  \n  const newReactions = reaction.new_reaction || [];\n  const oldReactions = reaction.old_reaction || [];\n  \n  // Reaction add hua\n  if (newReactions.length > 0) {\n    const emoji = newReactions[0]?.emoji || '';\n    reactionType = emoji === '👍' ? 'positive' : emoji === '👎' ? 'negative' : 'neutral';\n  }\n  // Reaction remove hua\n  else if (newReactions.length === 0 && oldReactions.length > 0) {\n    reactionType = 'neutral';\n  }\n} else if (callbackQuery) {\n  messageId = callbackQuery.message?.message_id;\n  chatId = callbackQuery.message?.chat?.id;\n  userId = callbackQuery.from?.id;\n  reactionType = callbackQuery.data === 'like' ? 'positive' : 'negative';\n}\n\nif (!messageId || !reactionType || reactionType === 'neutral') {\n  return [{ json: { skip: true, body: body } }];\n}\n\nreturn [{ json: { messageId, chatId, userId, reactionType, raw: body } }];"
      },
