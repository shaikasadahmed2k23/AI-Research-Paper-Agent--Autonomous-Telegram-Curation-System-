    {
      "parameters": {
        "jsCode": "const papers = $('Pick Top 5 of Week').first().json.papers || [];\nconst weekStart = $('Pick Top 5 of Week').first().json.week_start || '';\n\nconst paperList = papers.map(p => ({\n  title: p.title,\n  tldr: p.tldr || '',\n  source: p.source,\n  liked: p.user_reaction === 'positive'\n}));\n\nconst prompt = `Write a weekly AI research digest for a CS student focused on AI/ML/NLP.\n\nTop papers this week:\n${JSON.stringify(paperList, null, 2)}\n\nWrite a short engaging digest (max 400 words):\n1. One punchy opening sentence about the week theme\n2. Each paper in 2-3 lines max\n3. Note which were liked by user if any\n4. One closing trend line\n\nFormat for Telegram Markdown. Use *bold* for paper titles. No extra commentary.`;\n\nreturn [{\n  json: {\n    model: \"llama-3.3-70b-versatile\",\n    temperature: 0.7,\n    messages: [{ role: \"user\", content: prompt }]\n  }\n}];"
