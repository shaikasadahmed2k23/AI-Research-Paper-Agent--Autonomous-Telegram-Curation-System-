    {
      "parameters": {
        "jsCode": "const papers = $input.all().map(i => i.json);\nif (papers.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\n// Sort: prioritize liked papers, then by score\nconst sorted = papers.sort((a, b) => {\n  const aLiked = a.user_reaction === 'positive' ? 10 : 0;\n  const bLiked = b.user_reaction === 'positive' ? 10 : 0;\n  return (bLiked + b.score) - (aLiked + a.score);\n});\n\nconst top5 = sorted.slice(0, 5);\nreturn [{ json: { papers: top5, week_start: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toLocaleDateString() } }];\n"
      },
