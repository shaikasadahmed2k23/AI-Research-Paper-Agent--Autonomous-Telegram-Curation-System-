    {
      "parameters": {
        "jsCode": "const allSources = $input.all();\nconst papers = [];\n\nallSources.forEach(source => {\n  const data = source.json;\n\n  // arXiv — comes as raw XML string in data.data\n  if (data.data && typeof data.data === 'string' && data.data.includes('<feed')) {\n    const xml = data.data;\n    const entries = xml.split('<entry>').slice(1);\n    entries.forEach(entry => {\n      const getId = (tag) => {\n        const m = entry.match(new RegExp(`<${tag}[^>]*>([\\\\s\\\\S]*?)<\\\\/${tag}>`));\n        return m ? m[1].trim() : '';\n      };\n      const id = getId('id');\n      const title = getId('title').replace(/\\s+/g, ' ');\n      const summary = getId('summary').replace(/\\s+/g, ' ');\n      const published = getId('published');\n      const authorMatches = [...entry.matchAll(/<name>([\\s\\S]*?)<\\/name>/g)];\n      const authors = authorMatches.map(m => m[1].trim()).join(', ');\n      if (title) {\n        papers.push({ id, title, abstract: summary, authors, url: id, source: 'arxiv', published });\n      }\n    });\n  }\n\n  // HuggingFace — array of objects with paper key\n  if (Array.isArray(data) && data[0]?.paper) {\n    data.forEach(p => {\n      if (p.paper?.title) {\n        papers.push({\n          id: p.paper?.id || '',\n          title: p.paper?.title || '',\n          abstract: p.paper?.summary || '',\n          authors: p.paper?.authors?.map(a => a.name).join(', ') || '',\n          url: `https://huggingface.co/papers/${p.paper?.id}`,\n          source: 'huggingface',\n          published: p.publishedAt || ''\n        });\n      }\n    });\n  }\n\n  // Semantic Scholar — has data.data array\n  if (data.data && Array.isArray(data.data)) {\n    data.data.forEach(p => {\n      if (p.title) {\n        papers.push({\n          id: p.paperId || '',\n          title: p.title || '',\n          abstract: p.abstract || '',\n          authors: p.authors?.map(a => a.name).join(', ') || '',\n          url: p.url || '',\n          source: 'semantic_scholar',\n          published: p.publicationDate || ''\n        });\n      }\n    });\n  }\n});\n\nreturn [{ json: { papers, total: papers.length } }];"
      },
      "id": "74a94d22-97f2-46b5-aabb-95fa6fa828a2",
      "name": "Normalize All Papers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -288,
        -32
      ]
    },
    {
      "parameters": {
        "jsCode": "const papers = $('Normalize All Papers').first().json.papers || [];\n\nlet sentSet = new Set();\ntry {\n  const sentItems = $('Get Sent Papers (Supabase)').all();\n  sentItems.forEach(i => {\n    if (i.json.paper_id) sentSet.add(i.json.paper_id);\n  });\n} catch(e) {\n  sentSet = new Set();\n}\n\nconst newPapers = papers.filter(p => p.id && !sentSet.has(p.id));\n\nconst seen = new Set();\nconst deduped = newPapers.filter(p => {\n  if (!p.title) return false;\n  const key = p.title.toLowerCase().slice(0, 60);\n  if (seen.has(key)) return false;\n  seen.add(key);\n  return true;\n});\n\nreturn [{ json: { papers: deduped, count: deduped.length } }];"
      },
      "id": "ab1c8cea-b1dd-4a72-9321-91891e758448",
      "name": "Dedup & Filter New",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const rankingRaw = $('Groq: Rank & Summarize').first().json.choices[0].message.content;\n\nconst papers = $('Dedup & Filter New').first().json.papers;\n\nlet rankings;\ntry {\n  const cleaned = rankingRaw.replace(/```json|```/g, '').trim();\n  rankings = JSON.parse(cleaned);\n} catch(e) {\n  return [{ json: { error: 'Failed to parse Claude response', raw: rankingRaw } }];\n}\n\nconst finalPapers = rankings\n  .slice(0, 8)\n  .map(r => ({\n    ...papers[r.index],\n    score: r.score,\n    tldr: r.tldr,\n    why_relevant: r.why_relevant\n  }))\n  .filter(p => p.title);\n\nreturn finalPapers.map(p => ({ json: p }));"
      },
