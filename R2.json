    {
      "parameters": {
        "jsCode": "const paper = $('Lookup Paper by Message ID').first().json;\nconst reaction = $('Parse Reaction').first().json;\n\nif (!paper?.paper_id) {\n  return [{ json: { skip: true, reason: 'paper not found' } }];\n}\n\n// Extract topic keywords from title for preference scoring\nconst titleWords = paper.title\n  .toLowerCase()\n  .split(/\\s+/)\n  .filter(w => w.length > 4 && !['about','which','using','their','these','with','from','that'].includes(w));\n\nconst topicKeywords = titleWords.slice(0, 3).join('_');\n\nreturn [{\n  json: {\n    paper_id: paper.paper_id,\n    title: paper.title,\n    source: paper.source,\n    score_delta: reaction.reactionType === 'positive' ? 1 : -1,\n    reaction: reaction.reactionType,\n    topic_keywords: topicKeywords\n  }\n}];"
      },
